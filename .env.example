# LLM (optional — default is mock LLM for local/CI)
# LOOM_RUN_MOCK_LLM=1
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Run defaults
# LOOM_RUN_WORKSPACE=/absolute/path/to/workspace
# LOOM_RUN_MAX_TOOL_CALLS=3
# LOOM_RUN_USER_MESSAGE=

# Optional MCP servers (stdio). When unset, local tool fallbacks are used.
# MCP config JSON path (see mcp.servers.example.json)
# LOOM_RUN_MCP_CONFIG=/absolute/path/to/mcp.servers.json

# SQLite checkpoint DB (CLI default)
# LOOM_RUN_DB=runs.sqlite

# HTTP server (loom-run serve)
# LOOM_RUN_HOST=127.0.0.1
# LOOM_RUN_PORT=8765
